table olist_order_items_dataset
	lineageTag: 5177d77c-7a47-4a17-9cfd-a025b1cdb6ce

	measure 'Total Revenue' = sum(olist_order_items_dataset[Total Amount ])
		formatString: \$#,0.0;(\$#,0.0);\$#,0.0
		lineageTag: 6dade941-b315-40c6-b611-1f92354883fb

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	measure 'PYTD Revenue' = CALCULATE(SUM(olist_order_items_dataset[Total Amount ]),SAMEPERIODLASTYEAR(olist_orders_dataset[order_purchase_timestamp].[Date]))
		lineageTag: 2126d39e-dbd1-4e50-a7d7-aeba4aafd5df

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'YOY Sales' = DIVIDE([Total Revenue]-12000000,12000000)
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: ac474e29-4930-41cc-b4fc-748a9c3801c6

	measure 'Grouth Indicater' =
			
			SWITCH(
			    TRUE(),
			    [YOY Sales] > 0,UNICHAR(9650),
			    [YOY Sales] < 0,UNICHAR(9660),
			    UNICHAR(8213)
			)
		lineageTag: 9095a44b-9f1b-4633-9a99-42a13ab49495

	measure 'sales colour' = if([YOY Sales]>0,"Green","Red")
		lineageTag: 742cb851-5632-4da4-9d48-1f8a1618191d

	measure 'Total Order' = DISTINCTCOUNT(olist_orders_dataset[order_id])
		formatString: #,0.0
		lineageTag: 2f3fb1b7-4966-4862-b0ab-d6362826e1e1

	measure 'Average Order Value' = DIVIDE([Total Revenue],[Total Order])
		formatString: \$#,0.0;(\$#,0.0);\$#,0.0
		lineageTag: 2d3b125c-dc9f-45f3-aa95-1ad24d9c52ee

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	measure 'PYTD Orders' = CALCULATE(DISTINCTCOUNT(olist_order_items_dataset[order_id]),SAMEPERIODLASTYEAR(olist_orders_dataset[order_purchase_timestamp].[Date]))
		formatString: 0
		lineageTag: 99191f2b-4201-4750-a21c-99bfb8b7539d

	measure 'YOY Oders' = DIVIDE(olist_order_items_dataset[Total Order]-85000,85000)
		formatString: 0.0%;-0.0%;0.0%
		lineageTag: d5302559-6a8b-472b-9ad5-cf538e0716aa

	measure 'Order Indicater' =
			
			SWITCH(
			    TRUE(),
			    [YOY Oders] > 0,UNICHAR(9650),
			    [YOY Oders] < 0,UNICHAR(9660),
			    UNICHAR(8213)
			)
		lineageTag: dbfb55af-0299-4cda-bc53-10083471847b

	measure 'Order colour' = if([YOY Oders]>0,"Green","Red")
		lineageTag: f6ca580e-e8d0-4055-8da3-a85a41a407e8

	measure 'PYTD Average Order Value' = CALCULATE(olist_order_items_dataset[Average Order Value](SAMEPERIODLASTYEAR(olist_orders_dataset[order_purchase_timestamp].[Date])))
		lineageTag: 904057f6-c114-4958-a2d0-324c57b79fff

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'YOY Average Order Value' = DIVIDE(olist_order_items_dataset[Average Order Value]-olist_order_items_dataset[PYTD Average Order Value],olist_order_items_dataset[PYTD Average Order Value] )
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: bc8a47b1-8a90-41fb-ae34-729f39654735

	measure 'AOV colour' = if([YOY Average Order Value]>0,"Green","Red")
		lineageTag: 0c46cffc-5e4e-4907-acf5-90899eeaf679

	measure 'AOV Indicater' =
			
			SWITCH(
			    TRUE(),
			    [YOY Average Order Value] > 0,UNICHAR(9650),
			    [YOY Average Order Value] < 0,UNICHAR(9660),
			    UNICHAR(8213)
			)
		lineageTag: db0a30ce-b00b-499b-832d-04e9b462638e

	measure 'Assumed Margin' = 0.30
		lineageTag: f414aff7-a502-4cc9-842a-682922085c07

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Total Profit' = ```
			[Total Revenue]*[Assumed Margin] 
			```
		formatString: \$#,0.0;(\$#,0.0);\$#,0.0
		lineageTag: 61750851-aa46-4788-bff2-e9f348dda9fa

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	measure 'Profit Margin %' = ```
			DIVIDE([Total Profit],[Total Revenue]) 
			```
		formatString: 0%;-0%;0%
		lineageTag: e665321b-3e8c-490e-a887-755f82f3f11e

	measure 'profit Indicater' =
			
			SWITCH(
			    TRUE(),
			    [Profit Margin %] > 0,UNICHAR(9650),
			    [Profit Margin %] < 0,UNICHAR(9660),
			    UNICHAR(8213)
			)
		lineageTag: 04c0ec94-a8b9-4d2d-a8b5-1dd3b4270799

	measure 'Porfit colour' = if([Profit Margin %]>0,"Green","Red")
		lineageTag: 4959e44a-bc8c-4834-a917-a9695921bfa2

	measure 'Pre M R' = CALCULATE([Total Revenue],PREVIOUSMONTH(olist_orders_dataset[order_purchase_timestamp].[Date]))
		lineageTag: ffa6f408-44d2-490f-90ed-40a13d49dec5

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'MoM %' = ```
			DIVIDE([Total Revenue]-[Pre M R],[Pre M R]) 
			```
		lineageTag: cc27494c-b516-4ef2-a84c-2e61f87e7eed

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure Status =
			SWITCH(TRUE(),[MoM %]>0.10,"Peak",
			                      [MoM %]<-0.10,"Low",
			                      "Good"
			)
		lineageTag: 4f1ed6be-9332-4d99-a117-dae372a8ed8e

	measure 'Previous Salse' = CALCULATE([Total Revenue],PREVIOUSMONTH(olist_orders_dataset[Order Date]))
		lineageTag: b30b8c62-f9e4-4be7-9932-1c0175031f9e

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Salse Growth' = DIVIDE([Total Revenue]-(6500000),(6500000))
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 360d8bb7-06b0-4020-bf1d-882c6d529f91

	measure 'Sales Target' = 15000000
		formatString: 0
		lineageTag: f10a889f-42c2-4aa1-b451-4f6109bb0dc0

		annotation PBI_FormatHint = {"isDecimal":true}

	measure 'Sales target Achievement' = DIVIDE([Total Revenue],[Sales Target],0)
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 72038e21-d02a-4c22-a73b-be37a207729d

