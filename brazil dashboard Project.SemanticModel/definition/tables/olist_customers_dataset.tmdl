table olist_customers_dataset
	lineageTag: 37d410bf-85ef-483d-bdea-11cda2733224

	measure 'Best Region' = TOPN(1,VALUES('Table'[state name]))
		lineageTag: 592ee81a-86af-486d-b272-11bd078ced03

	measure 'Total customers' = DISTINCTCOUNT(olist_customers_dataset[customer_id])
		formatString: 0
		lineageTag: 3a92d3c6-2caf-4c9c-af00-9a0a9e229981

	measure 'Best Region City' = TOPN(1,VALUES(olist_customers_dataset[customer_city]))
		lineageTag: f0a632f3-3107-460c-bd7e-fe3a4e4c6756

	measure 'BRS Count' = CALCULATE(DISTINCTCOUNT(olist_customers_dataset[customer_id]),olist_customers_dataset[customer_state]="SP")
		formatString: 0
		lineageTag: 30a344e7-fb48-43be-a0bf-2df1197201d6

	measure 'BRC Count' = CALCULATE(DISTINCTCOUNT(olist_customers_dataset[customer_id]),olist_customers_dataset[customer_city]="franca")
		formatString: 0
		lineageTag: 28ec04f5-75c2-44cc-88c6-7b7451356bae

	column customer_id
