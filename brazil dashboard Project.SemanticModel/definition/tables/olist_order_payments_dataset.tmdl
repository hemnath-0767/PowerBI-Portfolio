table olist_order_payments_dataset
	lineageTag: bdb8a39c-2b9c-495c-bb06-1d7a3b971dde

	measure 'Top Payment type' = TOPN(1,VALUES('olist_order_payments_dataset'[payment_type]))
		lineageTag: ea0e4fff-1710-4994-ab6e-0a3fafa39634

	measure 'Credit Card' =
			CALCULATE(COUNT(olist_order_payments_dataset[payment_type]),olist_order_payments_dataset[payment_type]="Credit Card"
			)
		formatString: 0
		lineageTag: a8228bb2-2fab-45c4-b3a7-7d6ff143a5c0

	measure 'Credit Card %' = ```
			DIVIDE([Credit Card],COUNT(olist_order_payments_dataset[payment_type])) 
			```
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 81ec87e0-174a-4007-a8cc-74e6539e4d73

	measure Revenue = ```
			SUM(olist_order_payments_dataset[payment_value]) 
			```
		formatString: 0
		lineageTag: 9ee4f149-e9d3-4285-9551-cff6c43b65a4

