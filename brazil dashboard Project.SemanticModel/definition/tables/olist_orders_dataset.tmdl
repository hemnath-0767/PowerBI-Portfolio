table olist_orders_dataset
	lineageTag: 52d4b67a-2ad6-4e9d-bfad-5b527e1ffab4

	measure 'MoM Display' = IF([MoM %]>0,UNICHAR(9650)& " " & FORMAT([MoM %],"0.0%"),UNICHAR(9660) &" "& FORMAT(ABS([MoM %]),"0.0%"))
		lineageTag: aea1fc3d-eee9-4a5f-9786-7ceed1bb404a

	measure 'delivered Order' = CALCULATE(COUNT(olist_orders_dataset[order_id]),olist_orders_dataset[Order Status ]="completed")
		formatString: 0
		lineageTag: feacace7-5962-426a-817f-f69ea86abe81

	measure 'Order completed %' = DIVIDE(CALCULATE([delivered Order]),COUNT(olist_orders_dataset[order_id]))
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 04b9c9a6-16a2-4afa-8464-ca1484f6e6ac

	measure 'Cancel rate' = DIVIDE(CALCULATE(COUNTROWS(olist_orders_dataset),olist_orders_dataset[Order Status ]="canceled"),COUNTROWS(olist_orders_dataset))
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 646f66ef-c609-4a37-a24f-597293523802

